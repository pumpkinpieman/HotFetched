// TEMPLATE ONLY — verify physical SWD pads and target voltage first.
// Start J-Link Commander with a generic Cortex-M4 target, SWD, 50–100 kHz.
// Substitute PROBE_HEX with the correct SPC2168 or SPC1168 probe path.
h
loadfile PROBE_HEX
wreg R13 0x20003F00
wreg R15 0x20000009
g
sleep 250
h
mem32 0x20003C00, 8
// Do not erase, unlock, mass-erase, or program flash.
