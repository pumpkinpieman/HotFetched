{
  "id": "btt_skr_v3_0",
  "name": "BigTreeTech SKR 3",
  "vendor": "BigTreeTech",
  "mcu_variants": [
    {
      "id": "STM32H743VI",
      "label": "STM32H743VIT6 (480 MHz, 2 MB flash)",
      "marlin_env": "STM32H743VI_btt",
      "klipper_mcu": "stm32h743xx",
      "klipper_mach": "CONFIG_MACH_STM32H743"
    },
    {
      "id": "STM32H723VG",
      "label": "STM32H723VGT6 (550 MHz, 1 MB flash)",
      "marlin_env": "STM32H723Vx_btt",
      "klipper_mcu": "stm32h723xx",
      "klipper_mach": "CONFIG_MACH_STM32H723",
      "marlin_env_aliases": [
        "STM32H723VG_btt"
      ]
    }
  ],
  "marlin": {
    "motherboard": "BOARD_BTT_SKR_V3_0",
    "serial_ports": [
      1,
      -1
    ],
    "driver_slots": [
      "X",
      "Y",
      "Z",
      "E0",
      "E1"
    ],
    "valid_drivers": [
      "TMC2209",
      "TMC2208",
      "TMC2130",
      "TMC5160",
      "A4988",
      "DRV8825",
      "LV8729"
    ],
    "onboard_uart_drivers": true,
    "max_extruders": 2,
    "screens": [
      {
        "id": "none",
        "label": "None / headless",
        "type": "none"
      },
      {
        "id": "REPRAP_DISCOUNT_SMART_CONTROLLER",
        "label": "RepRapDiscount Smart Controller (20x4 character LCD)",
        "type": "char20x4"
      },
      {
        "id": "REPRAP_DISCOUNT_FULL_GRAPHIC_SMART_CONTROLLER",
        "label": "RepRap Discount Full Graphic 12864",
        "type": "mono128x64"
      },
      {
        "id": "CR10_STOCKDISPLAY",
        "label": "Creality CR-10 stock display (12864)",
        "type": "mono128x64"
      },
      {
        "id": "MKS_MINI_12864_V3",
        "label": "MKS Mini 12864 V3",
        "type": "mono128x64"
      },
      {
        "id": "FYSETC_MINI_12864_2_1",
        "label": "FYSETC Mini 12864 2.1 (RGB)",
        "type": "mono128x64"
      },
      {
        "id": "BTT_MINI_12864",
        "label": "BigTreeTech Mini 12864",
        "type": "mono128x64"
      },
      {
        "id": "btt_tft_marlin_mode",
        "label": "BTT TFT35/TFT70 (Marlin mode + touch — EXP1/EXP2 wired)",
        "type": "marlinui_tft",
        "define": "REPRAP_DISCOUNT_FULL_GRAPHIC_SMART_CONTROLLER"
      },
      {
        "id": "btt_serial_tft",
        "label": "BTT TFT35/TFT70 (touch mode only — no Marlin menus/beeper)",
        "type": "serial_tft"
      }
    ],
    "probes": [
      {
        "id": "none",
        "label": "No probe (manual leveling)",
        "enable": [],
        "disable": [
          "BLTOUCH",
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ]
      },
      {
        "id": "bltouch",
        "label": "BLTouch / CR Touch (dedicated probe port)",
        "enable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "FIX_MOUNTED_PROBE"
        ]
      },
      {
        "id": "fixed_probe_port",
        "label": "Fixed inductive/capacitive probe (probe port)",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "BLTOUCH"
        ]
      },
      {
        "id": "fixed_probe_zmin",
        "label": "Fixed probe wired to Z-min endstop",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING"
        ]
      }
    ]
  },
  "klipper": {
    "reference_config": "generic-bigtreetech-skr-3.cfg",
    "config_seed": [
      "CONFIG_MACH_STM32=y",
      "{MACH}=y",
      "CONFIG_STM32_FLASH_START_20000=y",
      "CONFIG_STM32_CLOCK_REF_25M=y",
      "CONFIG_USBSERIAL=y"
    ],
    "kconfig": {
      "FLASH_APPLICATION_ADDRESS": "0x8020000"
    },
    "flash_note": "Copy out/klipper.bin to SD as firmware.bin (128KiB bootloader).",
    "mach": "CONFIG_MACH_STM32H743",
    "artifact": "klipper.bin"
  },
  "limits": {
    "max_bed_x": 500,
    "max_bed_y": 500,
    "max_z": 600,
    "max_hotend_temp": 350,
    "max_bed_temp": 130,
    "max_feedrate_xy": 500,
    "max_feedrate_z": 20
  },
  "firmware_support": {
    "marlin": true,
    "klipper": true,
    "reprap": true
  },
  "min_marlin": "2.1.2",
  "wifi": {
    "supported": false,
    "module": null,
    "note": "Marlin's WIFISUPPORT pulls in ESP32-only libraries (ESP3DLib, AsyncTCP, WebSockets) and only builds when the mainboard itself is an ESP32. An ESP-01/ESP-01S in this board's WiFi header runs its OWN firmware (ESP3D or BTT's) flashed separately - Marlin needs no feature enabled for it, just a spare serial port."
  },
  "rrf": {
    "supported": true,
    "asset_include": [
      "skr3"
    ],
    "asset_exclude": [
      "ez"
    ],
    "docs_url": "https://teamgloomy.github.io/skr_3_h723_general_3_5.html",
    "note": "TeamGloomy ships prebuilt per-board firmware; HotFetched generates config.g and fetches the matching binary."
  },
  "ui": {
    "lcd": true,
    "beeper": true,
    "neopixel": true,
    "z_steppers": 1
  }
}
