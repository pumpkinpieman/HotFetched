{
  "id": "btt_octopus_pro_v1_0",
  "name": "BigTreeTech Octopus Pro V1.0 (F446)",
  "vendor": "BigTreeTech",
  "mcu_variants": [
    {
      "id": "STM32F446",
      "label": "STM32F446ZE (180 MHz)",
      "marlin_env": "STM32F446ZE_btt",
      "klipper_mcu": "stm32f446xx",
      "klipper_mach": "CONFIG_MACH_STM32F446"
    }
  ],
  "firmware_support": {
    "marlin": true,
    "klipper": true,
    "reprap": false
  },
  "marlin": {
    "motherboard": "BOARD_BTT_OCTOPUS_PRO_V1_0",
    "serial_ports": [
      1,
      -1
    ],
    "driver_slots": [
      "X",
      "Y",
      "Z",
      "Z2",
      "E0",
      "E1",
      "E2",
      "E3"
    ],
    "valid_drivers": [
      "TMC2209",
      "TMC2208",
      "TMC2130",
      "TMC5160",
      "A4988",
      "DRV8825"
    ],
    "onboard_uart_drivers": true,
    "max_extruders": 4,
    "screens": [
      {
        "id": "none",
        "label": "None / headless",
        "type": "none"
      },
      {
        "id": "REPRAP_DISCOUNT_FULL_GRAPHIC_SMART_CONTROLLER",
        "label": "RepRap Discount Full Graphic 12864",
        "type": "mono128x64"
      },
      {
        "id": "CR10_STOCKDISPLAY",
        "label": "Creality CR-10 stock display (12864)",
        "type": "mono128x64"
      },
      {
        "id": "MKS_MINI_12864_V3",
        "label": "MKS Mini 12864 V3",
        "type": "mono128x64"
      },
      {
        "id": "FYSETC_MINI_12864_2_1",
        "label": "FYSETC Mini 12864 2.1 (RGB)",
        "type": "mono128x64"
      },
      {
        "id": "BTT_MINI_12864",
        "label": "BigTreeTech Mini 12864",
        "type": "mono128x64"
      },
      {
        "id": "btt_tft_marlin_mode",
        "label": "BTT TFT35/TFT70 (Marlin mode + touch \u2014 EXP1/EXP2 wired)",
        "type": "marlinui_tft",
        "define": "REPRAP_DISCOUNT_FULL_GRAPHIC_SMART_CONTROLLER"
      },
      {
        "id": "btt_serial_tft",
        "label": "BTT TFT35/TFT70 (touch mode only \u2014 no Marlin menus/beeper)",
        "type": "serial_tft"
      }
    ],
    "probes": [
      {
        "id": "none",
        "label": "No probe (manual leveling)",
        "enable": [],
        "disable": [
          "BLTOUCH",
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ]
      },
      {
        "id": "bltouch",
        "label": "BLTouch / CR Touch (dedicated probe port)",
        "enable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "FIX_MOUNTED_PROBE"
        ]
      },
      {
        "id": "fixed_probe_port",
        "label": "Fixed inductive/capacitive probe (probe port)",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "BLTOUCH"
        ]
      },
      {
        "id": "fixed_probe_zmin",
        "label": "Fixed probe wired to Z-min endstop",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING"
        ]
      }
    ]
  },
  "klipper": {
    "reference_config": "generic-bigtreetech-octopus-pro-v1.0.cfg",
    "config_seed": [
      "CONFIG_LOW_LEVEL_OPTIONS=y",
      "CONFIG_MACH_STM32=y",
      "CONFIG_MACH_STM32F446=y",
      "CONFIG_STM32_FLASH_START_8000=y",
      "CONFIG_STM32_CLOCK_REF_12M=y",
      "CONFIG_USBSERIAL=y"
    ],
    "kconfig": {
      "FLASH_APPLICATION_ADDRESS": "0x8008000"
    },
    "flash_note": "Copy out/klipper.bin to the SD card as firmware.bin and power-cycle to flash.",
    "mach": "CONFIG_MACH_STM32F446",
    "artifact": "klipper.bin"
  },
  "limits": {
    "max_bed_x": 400,
    "max_bed_y": 400,
    "max_z": 500,
    "max_hotend_temp": 350,
    "max_bed_temp": 150,
    "max_feedrate_xy": 800,
    "max_feedrate_z": 40
  },
  "min_marlin": "2.1.1",
  "note": "Octopus Pro V1.0 ships in F446, F429 and H723 variants - this entry targets the F446. Check the chip marking before flashing.",
  "wifi": {
    "supported": false,
    "module": null,
    "note": "Marlin's WIFISUPPORT pulls in ESP32-only libraries (ESP3DLib, AsyncTCP, WebSockets) and only builds when the mainboard itself is an ESP32. An ESP-01/ESP-01S in this board's WiFi header runs its OWN firmware (ESP3D or BTT's) flashed separately - Marlin needs no feature enabled for it, just a spare serial port."
  },
  "rrf": {
    "supported": false,
    "asset_include": [],
    "asset_exclude": [],
    "docs_url": null,
    "note": "RRF (TeamGloomy) supports only the STM32F429 Octopus Pro v1.0 - this entry is the F446 variant, so RRF is not offered."
  },
  "ui": {
    "lcd": true,
    "beeper": true,
    "neopixel": true,
    "z_steppers": 2
  }
}