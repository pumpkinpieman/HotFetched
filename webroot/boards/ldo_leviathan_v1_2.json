{
  "id": "ldo_leviathan_v1_2",
  "name": "LDO Leviathan V1.2 (Voron, F446)",
  "vendor": "LDO Motors",
  "mcu_variants": [
    {
      "id": "STM32F446",
      "label": "STM32F446ZET6 (180 MHz)",
      "marlin_env": null,
      "klipper_mcu": "stm32f446xx",
      "klipper_mach": "CONFIG_MACH_STM32F446"
    }
  ],
  "firmware_support": {
