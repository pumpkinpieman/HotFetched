        "label": "RepRap Discount Full Graphic 12864",
        "type": "mono128x64"
      },
      {
        "id": "CR10_STOCKDISPLAY",
        "label": "Creality CR-10 stock display (12864)",
        "type": "mono128x64"
      },
      {
        "id": "MKS_MINI_12864_V3",
        "label": "MKS Mini 12864 V3",
        "type": "mono128x64"
      },
      {
        "id": "FYSETC_MINI_12864_2_1",
        "label": "FYSETC Mini 12864 2.1 (RGB)",
        "type": "mono128x64"
      },
      {
        "id": "BTT_MINI_12864",
        "label": "BigTreeTech Mini 12864",
        "type": "mono128x64"
      },
      {
        "id": "btt_serial_tft",
        "label": "BTT TFT35/TFT70 (touch mode, external firmware)",
        "type": "serial_tft"
      }
    ],
    "probes": [
      {
        "id": "none",
        "label": "No probe (manual leveling)",
        "enable": [],
        "disable": [
          "BLTOUCH",
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ]
      },
      {
        "id": "bltouch",
        "label": "BLTouch / CR Touch (dedicated probe port)",
        "enable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "FIX_MOUNTED_PROBE"
        ]
      },
      {
        "id": "fixed_probe_port",
        "label": "Fixed inductive/capacitive probe (probe port)",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "BLTOUCH"
        ]
      },
      {
        "id": "fixed_probe_zmin",
        "label": "Fixed probe wired to Z-min endstop",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING"
        ]
      }
    ]
  },
  "klipper": {
    "reference_config": "generic-ldo-leviathan-v1.2.cfg",
    "config_seed": [
      "CONFIG_MACH_STM32F446=y",
      "CONFIG_STM32_FLASH_START_8000=y",
      "CONFIG_STM32_CLOCK_REF_12M=y",
      "CONFIG_USBSERIAL=y"
    ],
    "kconfig": {
      "FLASH_APPLICATION_ADDRESS": "0x8008000"
    },
    "flash_note": "Flash out/klipper.bin over USB DFU (hold BOOT + tap RESET), or via a Catapult/CanBoot bootloader from the Pi. This Voron board has no SD-card firmware slot.",
    "mach": "CONFIG_MACH_STM32F446",
    "artifact": "klipper.bin"
  },
  "min_marlin": "\u2014",
  "note": "Voron-specific integrated board (5x TMC2209 + 2x TMC5160 onboard, RPi mount). Klipper only \u2014 Marlin has no board definition for it (LDO lists Marlin as TBD). The generic config assumes a Voron CoreXY; adjust steppers/limits for your machine. V1.3 uses an STM32H743 and needs a different config not yet shipped upstream.",
  "limits": {
    "max_bed_x": 400,
    "max_bed_y": 400,
    "max_z": 500,
    "max_hotend_temp": 350,
    "max_bed_temp": 130,
    "max_feedrate_xy": 800,
    "max_feedrate_z": 40
  }
}