{
  "id": "btt_skr_e3_turbo",
  "name": "BigTreeTech SKR E3 Turbo (LPC1769)",
  "vendor": "BigTreeTech",
  "mcu_variants": [
    {
      "id": "LPC1769",
      "label": "LPC1769 (120 MHz)",
      "marlin_env": "LPC1769",
      "klipper_mcu": "lpc1769",
      "klipper_mach": "CONFIG_MACH_LPC1769"
    }
  ],
  "firmware_support": {
    "marlin": true,
    "klipper": true,
    "reprap": true
  },
  "marlin": {
    "motherboard": "BOARD_BTT_SKR_E3_TURBO",
    "serial_ports": [
      1,
      -1
    ],
    "driver_slots": [
      "X",
      "Y",
      "Z",
      "E0",
      "E1"
    ],
    "valid_drivers": [
      "TMC2209",
      "TMC2208",
      "TMC2130",
      "TMC5160",
      "A4988",
      "DRV8825"
    ],
    "onboard_uart_drivers": true,
    "max_extruders": 2,
    "screens": [
      {
        "id": "none",
        "label": "None / headless",
        "type": "none"
      },
      {
        "id": "REPRAP_DISCOUNT_SMART_CONTROLLER",
        "label": "RepRapDiscount Smart Controller (20x4 character LCD)",
        "type": "char20x4"
      },
      {
        "id": "REPRAP_DISCOUNT_FULL_GRAPHIC_SMART_CONTROLLER",
        "label": "RepRap Discount Full Graphic 12864",
        "type": "mono128x64"
      },
      {
        "id": "CR10_STOCKDISPLAY",
        "label": "Creality CR-10 stock display (12864)",
        "type": "mono128x64"
      },
      {
        "id": "MKS_MINI_12864_V3",
        "label": "MKS Mini 12864 V3",
        "type": "mono128x64"
      },
      {
        "id": "FYSETC_MINI_12864_2_1",
        "label": "FYSETC Mini 12864 2.1 (RGB)",
        "type": "mono128x64"
      },
      {
        "id": "BTT_MINI_12864",
        "label": "BigTreeTech Mini 12864",
        "type": "mono128x64"
      },
      {
        "id": "btt_tft_marlin_mode",
        "label": "BTT TFT35/TFT70 (Marlin mode + touch — EXP1/EXP2 wired)",
        "type": "marlinui_tft",
        "define": "REPRAP_DISCOUNT_FULL_GRAPHIC_SMART_CONTROLLER"
      },
      {
        "id": "btt_serial_tft",
        "label": "BTT TFT35/TFT70 (touch mode only — no Marlin menus/beeper)",
        "type": "serial_tft"
      }
    ],
    "probes": [
      {
        "id": "none",
        "label": "No probe (manual leveling)",
        "enable": [],
        "disable": [
          "BLTOUCH",
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ]
      },
      {
        "id": "bltouch",
        "label": "BLTouch / CR Touch (dedicated probe port)",
        "enable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "FIX_MOUNTED_PROBE"
        ]
      },
      {
        "id": "fixed_probe_port",
        "label": "Fixed inductive/capacitive probe (probe port)",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "BLTOUCH"
        ]
      },
      {
        "id": "fixed_probe_zmin",
        "label": "Fixed probe wired to Z-min endstop",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING"
        ]
      }
    ]
  },
  "klipper": {
    "reference_config": "generic-bigtreetech-skr-e3-turbo.cfg",
    "config_seed": [
      "CONFIG_LOW_LEVEL_OPTIONS=y",
      "CONFIG_MACH_LPC176X=y",
      "CONFIG_MACH_LPC1769=y",
      "CONFIG_LPC_USB=y",
      "CONFIG_USBSERIAL=y"
    ],
    "kconfig": {
      "FLASH_APPLICATION_ADDRESS": "0x4000"
    },
    "flash_note": "Copy out/klipper.bin to the SD card as firmware.bin (bootloader flashes on power-up).",
    "mach": "CONFIG_MACH_LPC1769",
    "artifact": "klipper.bin"
  },
  "limits": {
    "max_bed_x": 300,
    "max_bed_y": 300,
    "max_z": 400,
    "max_hotend_temp": 300,
    "max_bed_temp": 120,
    "max_feedrate_xy": 500,
    "max_feedrate_z": 25
  },
  "min_marlin": "2.0.7",
  "note": "SKR E3 Turbo - E3-form-factor LPC1769 with 5 drivers.",
  "wifi": {
    "supported": false,
    "module": null,
    "note": "Marlin's WIFISUPPORT pulls in ESP32-only libraries (ESP3DLib, AsyncTCP, WebSockets) and only builds when the mainboard itself is an ESP32. An ESP-01/ESP-01S in this board's WiFi header runs its OWN firmware (ESP3D or BTT's) flashed separately - Marlin needs no feature enabled for it, just a spare serial port."
  },
  "rrf": {
    "supported": true,
    "asset_include": [
      "e3turbo"
    ],
    "asset_exclude": [],
    "docs_url": "https://teamgloomy.github.io/skr_E3T_pins.html",
    "note": "TeamGloomy ships prebuilt per-board firmware; HotFetched generates config.g and fetches the matching binary."
  },
  "ui": {
    "lcd": true,
    "beeper": true,
    "neopixel": false,
    "z_steppers": 1
  }
}
