{
  "id": "btt_kraken_v1_0",
  "name": "BigTreeTech Kraken V1.0 (H723)",
  "vendor": "BigTreeTech",
  "mcu_variants": [
    {
      "id": "STM32H723ZG",
      "label": "STM32H723ZGT6 (550 MHz)",
      "marlin_env": "STM32H723ZG_btt",
      "klipper_mcu": "stm32h723xx"
    }
  ],
  "firmware_support": {
    "marlin": true,
    "klipper": false,
    "reprap": true
  },
  "marlin": {
    "motherboard": "BOARD_BTT_KRAKEN_V1_0",
    "serial_ports": [
      1,
      -1
    ],
    "driver_slots": [
      "X",
      "Y",
      "Z",
      "E0",
      "E1",
      "E2",
      "E3"
    ],
    "valid_drivers": [
      "TMC2209",
      "TMC2208",
      "TMC2130",
      "TMC5160",
      "A4988",
      "DRV8825"
    ],
    "onboard_uart_drivers": true,
    "max_extruders": 4,
    "screens": [
      {
        "id": "none",
        "label": "None / headless",
        "type": "none"
      },
      {
        "id": "REPRAP_DISCOUNT_SMART_CONTROLLER",
        "label": "RepRapDiscount Smart Controller (20x4 character LCD)",
        "type": "char20x4"
      },
      {
        "id": "REPRAP_DISCOUNT_FULL_GRAPHIC_SMART_CONTROLLER",
        "label": "RepRap Discount Full Graphic 12864",
        "type": "mono128x64"
      },
      {
        "id": "CR10_STOCKDISPLAY",
        "label": "Creality CR-10 stock display (12864)",
        "type": "mono128x64"
      },
      {
        "id": "MKS_MINI_12864_V3",
        "label": "MKS Mini 12864 V3",
        "type": "mono128x64"
      },
      {
        "id": "FYSETC_MINI_12864_2_1",
        "label": "FYSETC Mini 12864 2.1 (RGB)",
        "type": "mono128x64"
      },
      {
        "id": "BTT_MINI_12864",
        "label": "BigTreeTech Mini 12864",
        "type": "mono128x64"
      },
      {
        "id": "btt_tft_marlin_mode",
        "label": "BTT TFT35/TFT70 (Marlin mode + touch — EXP1/EXP2 wired)",
        "type": "marlinui_tft",
        "define": "REPRAP_DISCOUNT_FULL_GRAPHIC_SMART_CONTROLLER"
      },
      {
        "id": "btt_serial_tft",
        "label": "BTT TFT35/TFT70 (touch mode only — no Marlin menus/beeper)",
        "type": "serial_tft"
      }
    ],
    "probes": [
      {
        "id": "none",
        "label": "No probe (manual leveling)",
        "enable": [],
        "disable": [
          "BLTOUCH",
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ]
      },
      {
        "id": "bltouch",
        "label": "BLTouch / CR Touch (dedicated probe port)",
        "enable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "FIX_MOUNTED_PROBE"
        ]
      },
      {
        "id": "fixed_probe_port",
        "label": "Fixed inductive/capacitive probe (probe port)",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "BLTOUCH"
        ]
      },
      {
        "id": "fixed_probe_zmin",
        "label": "Fixed probe wired to Z-min endstop",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING"
        ]
      }
    ]
  },
  "limits": {
    "max_bed_x": 600,
    "max_bed_y": 600,
    "max_z": 700,
    "max_hotend_temp": 350,
    "max_bed_temp": 130,
    "max_feedrate_xy": 800,
    "max_feedrate_z": 30
  },
  "note": "High-end 8-driver board with onboard TMC5160T Plus. Marlin builds now; a Klipper generic config isn't published upstream yet, so Klipper support is pending a reference cfg.",
  "min_marlin": "2.1.3",
  "wifi": {
    "supported": false,
    "module": null,
    "note": "Marlin's WIFISUPPORT pulls in ESP32-only libraries (ESP3DLib, AsyncTCP, WebSockets) and only builds when the mainboard itself is an ESP32. An ESP-01/ESP-01S in this board's WiFi header runs its OWN firmware (ESP3D or BTT's) flashed separately - Marlin needs no feature enabled for it, just a spare serial port."
  },
  "rrf": {
    "supported": true,
    "asset_include": [
      "kraken"
    ],
    "asset_exclude": [],
    "docs_url": "https://teamgloomy.github.io/btt_kraken_h723_general_3_5.html",
    "note": "TeamGloomy ships prebuilt per-board firmware; HotFetched generates config.g and fetches the matching binary."
  },
  "ui": {
    "lcd": true,
    "beeper": true,
    "neopixel": true,
    "z_steppers": 1
  }
}
