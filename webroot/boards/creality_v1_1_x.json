  "klipper": {
    "reference_config": "printer-creality-ender3-2018.cfg",
    "config_seed": [
      "CONFIG_LOW_LEVEL_OPTIONS=y",
      "CONFIG_MACH_AVR=y",
      "CONFIG_MACH_atmega1284p=y",
      "CONFIG_AVR_FREQ_16000000=y",
      "CONFIG_AVR_SERIAL_UART0=y"
    ],
    "kconfig": {
      "FLASH_APPLICATION_ADDRESS": "0x0"
    },
    "flash_note": "Klipper creates out/klipper.elf.hex. Stock Melzi bootloaders normally flash with avrdude at 57600 baud; Optiboot normally uses 115200 baud. Match the baud rate to the selected bootloader profile.",
    "mach": "CONFIG_MACH_atmega1284p",
    "artifact": "klipper.elf.hex"
  },
  "limits": {
    "max_bed_x": 2000,
    "max_bed_y": 2000,
    "max_z": 2000,
    "max_hotend_temp": 285,
    "max_bed_temp": 120,
    "max_feedrate_xy": 300,
    "max_feedrate_z": 20
