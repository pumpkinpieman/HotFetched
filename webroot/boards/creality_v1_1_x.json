{
  "id": "creality_v1_1_x",
  "name": "Creality V1.1.x (Melzi / ATmega1284P)",
  "vendor": "Creality",
  "mcu_variants": [
    {
      "id": "ATmega1284P_stock_optimized",
      "label": "ATmega1284P \u2014 stock Melzi bootloader, size-optimized (recommended)",
      "marlin_env": "melzi_optimized",
      "marlin_artifact": "firmware.hex",
      "artifact_format": "Intel HEX",
      "klipper_mcu": "atmega1284p",
      "klipper_mach": "CONFIG_MACH_atmega1284p",
      "bootloader": "Stock Melzi / Sanguino bootloader (4 KiB application-space reservation)",
      "upload_protocol": "arduino",
      "upload_speed": 57600,
      "max_flash_bytes": 126976,
      "flash_note": "Flash over the board's USB serial connection. Creality V1.1.x boards do not support Marlin SD-card firmware updates.",
      "flash_command": "avrdude -p atmega1284p -c arduino -b 57600 -P {PORT} -D -U flash:w:{FIRMWARE}:i",
      "clock_hz": 16000000,
      "flash_bytes": 131072,
      "sram_bytes": 16384,
      "eeprom_bytes": 4096,
      "bootloader_bytes": 4096
    },
