  "firmware_support": {
    "marlin": true,
    "klipper": true,
    "reprap": false
  },
  "marlin": {
    "motherboard": "BOARD_MELZI_CREALITY",
    "artifact": "firmware.hex",
    "artifact_format": "Intel HEX",
    "serial_ports": [
      0,
      -1
    ],
    "driver_slots": [
      "X",
      "Y",
      "Z",
      "E0"
    ],
    "valid_drivers": [
      "A4988",
      "TMC2208_STANDALONE"
    ],
    "onboard_uart_drivers": false,
    "max_extruders": 1,
    "screens": [
      {
        "id": "none",
        "label": "None / headless",
        "type": "none"
      },
      {
        "id": "CR10_STOCKDISPLAY",
        "label": "Creality CR-10 / Ender stock 12864 display",
        "type": "mono128x64"
      }
    ],
