      "CONFIG_MACH_LPC176X=y",
      "CONFIG_MACH_LPC1768=y",
      "CONFIG_LPC_USB=y",
      "CONFIG_USBSERIAL=y"
    ],
    "kconfig": {
      "FLASH_APPLICATION_ADDRESS": "0x4000"
    },
    "flash_note": "Copy out/klipper.bin to SD as firmware.bin (SKR 1.4 has a 16KB bootloader).",
    "mach": "CONFIG_MACH_LPC1768",
    "artifact": "klipper.bin"
  },
  "min_marlin": "2.0"
