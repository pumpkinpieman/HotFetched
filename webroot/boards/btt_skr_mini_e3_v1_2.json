{
  "id": "btt_skr_mini_e3_v1_2",
  "name": "BigTreeTech SKR Mini E3 V1.2 (F103)",
  "vendor": "BigTreeTech",
  "mcu_variants": [
    {
      "id": "STM32F103",
      "label": "STM32F103RC (72 MHz)",
      "marlin_env": "STM32F103RC_btt",
      "klipper_mcu": "stm32f103xe",
      "klipper_mach": "CONFIG_MACH_STM32F103"
