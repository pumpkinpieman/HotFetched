        "type": "mono128x64"
      },
      {
        "id": "BTT_MINI_12864",
        "label": "BigTreeTech Mini 12864",
        "type": "mono128x64"
      },
      {
        "id": "btt_serial_tft",
        "label": "BTT TFT35/TFT70 (touch mode, external firmware)",
        "type": "serial_tft"
      }
    ],
    "probes": [
      {
        "id": "none",
        "label": "No probe (manual leveling)",
        "enable": [],
        "disable": [
          "BLTOUCH",
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ]
      },
      {
        "id": "bltouch",
        "label": "BLTouch / CR Touch (dedicated probe port)",
        "enable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "FIX_MOUNTED_PROBE"
        ]
      },
      {
        "id": "fixed_probe_port",
        "label": "Fixed inductive/capacitive probe (probe port)",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "USE_PROBE_FOR_Z_HOMING",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "BLTOUCH"
        ]
      },
      {
        "id": "fixed_probe_zmin",
        "label": "Fixed probe wired to Z-min endstop",
        "enable": [
          "FIX_MOUNTED_PROBE",
          "Z_MIN_PROBE_USES_Z_MIN_ENDSTOP_PIN",
          "Z_SAFE_HOMING"
        ],
        "disable": [
          "BLTOUCH",
          "USE_PROBE_FOR_Z_HOMING"
        ]
      }
    ]
  },
  "klipper": {
    "reference_config": "generic-bigtreetech-skr-mini-e3-v1.2.cfg",
    "config_seed": [
      "CONFIG_LOW_LEVEL_OPTIONS=y",
      "CONFIG_MACH_STM32=y",
      "CONFIG_MACH_STM32F103=y",
      "CONFIG_STM32_FLASH_START_7000=y",
      "CONFIG_USBSERIAL=y",
      "CONFIG_INITIAL_PINS=!PC13"
    ],
    "kconfig": {
      "FLASH_APPLICATION_ADDRESS": "0x8007000"
    },
    "flash_note": "Copy out/klipper.bin to the SD card as firmware.bin and power-cycle to flash.",
    "mach": "CONFIG_MACH_STM32F103",
    "artifact": "klipper.bin"
  },
  "limits": {
    "max_bed_x": 300,
    "max_bed_y": 300,
    "max_z": 400,
    "max_hotend_temp": 300,
    "max_bed_temp": 120,
    "max_feedrate_xy": 500,
    "max_feedrate_z": 25
  },
  "min_marlin": "2.0.5",
  "note": "SKR Mini E3 V1.2 - Ender drop-in. Soldered TMC2209s. Klipper needs GPIO !PC13 set at startup (baked into the seed).",
